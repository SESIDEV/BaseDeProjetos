@model ProspeccoesViewModel
@using BaseDeProjetos.Helpers
@using BaseDeProjetos.Models.Enums
@using BaseDeProjetos.Models.ViewModels
@using Microsoft.AspNetCore.Http
@{
    ViewData["Title"] = "Funil de Vendas";

    var abasFunil = new List<AbaFunil>();

    var dadosDaRota = ViewContext.RouteData;
    string aba = dadosDaRota.Values["aba"] as string;
    string casa = dadosDaRota.Values["casa"] as string;
    string searchString = ViewBag.searchString as string;
    string anoFiltro = ViewContext.HttpContext.Request.Query["ano"].ToString();
    if (string.IsNullOrWhiteSpace(anoFiltro))
    {
        anoFiltro = dadosDaRota.Values["ano"] as string;
    }
    string temperatura = ViewBag.Temperatura as string;
    string fomento = ViewBag.Fomento as string;
    bool filtrosFunilAtivos = !string.IsNullOrWhiteSpace(searchString)
        || (!string.IsNullOrWhiteSpace(anoFiltro) && anoFiltro != "Todos")
        || (!string.IsNullOrWhiteSpace(temperatura) && temperatura != "Todos")
        || (!string.IsNullOrWhiteSpace(fomento) && fomento != "Todos");
    int qtdProspeccoesPlanejadas = Convert.ToInt32(ViewBag.ProspeccoesPlanejadasCount);
    int qtdProspeccoesAtivas = Convert.ToInt32(ViewBag.ProspeccoesAtivasCount);
    int qtdProspeccoesComProposta = Convert.ToInt32(ViewBag.ProspeccoesComProposta);
    int qtdProspeccoesContratacao = Convert.ToInt32(ViewBag.ProspeccoesContratacao);
    int qtdProspeccoesEncerradas = Convert.ToInt32(ViewBag.ProspeccoesEncerradas);
    int qtdProspeccoesConcluidas = Convert.ToInt32(ViewBag.ProspeccoesConcluidas);
    bool abaIndicadores = !string.IsNullOrEmpty(aba) && aba.ToLowerInvariant() == "indicadores";
    bool abaPlanejamentoIndicadores = !string.IsNullOrEmpty(aba) && aba.ToLowerInvariant() == "planejamento";
    bool abaReceitasIndicadores = !string.IsNullOrEmpty(aba) && aba.ToLowerInvariant() == "receitas";
    bool abaSegmentos = !string.IsNullOrEmpty(aba) && aba.ToLowerInvariant() == "segmentos";
    bool abaEspecialIndicadores = abaIndicadores || abaPlanejamentoIndicadores || abaReceitasIndicadores;
    var usuarioNivelFunil = ViewBag.usuarioNivel;
    bool usuarioPodeEditarPlanejamentoIndicadores = usuarioNivelFunil != null
        && (usuarioNivelFunil.ToString() == "Supervisor" || usuarioNivelFunil.ToString() == "Dev");

    if (string.IsNullOrEmpty(casa))
    {
        casa = ViewBag.UsuarioCasa as string;
    }

    if (aba == null)
    {
        aba = "ativas";
    }

    List<Instituto> institutos = new List<Instituto>((Instituto[])Enum.GetValues(typeof(Instituto))).Where(i => i != Instituto.Super).ToList();
}

<script>
    var casa = "@casa"
    var anoFunilDashboard = "@(string.IsNullOrWhiteSpace(anoFiltro) ? "Todos" : anoFiltro)"
</script>

<script src="~/js/utils/Dicionario.js" asp-append-version="true"></script>
<script src="~/js/cnae.js" asp-append-version="true"></script>
<script src="~/js/empresas.js" asp-append-version="true"></script>
<script src="~/js/FunildeVendas/modalPreCreateProsp.js" asp-append-version="true"></script>
<script src="~/js/FunildeVendas/modalEditProsp.js" asp-append-version="true"></script>
<script src="~/js/FunildeVendas/modalCreateProsp.js" asp-append-version="true"></script>
<script src="~/js/FunildeVendas/modalCreateEditFollowupProsp.js" asp-append-version="true"></script>
<script src="~/js/FunildeVendas/validacoesFunilDeVendas.js" asp-append-version="true"></script>

<link rel="stylesheet" href="~/css/FunilDeVendas/funilDeVendas.css" asp-append-version="true" />

<partial name="Header" view-data="@ViewData" />

<div class="app-wrapper">
    <div class="app-content pt-3 p-md-3 p-lg-4">
        <div class="container-xl">
            @if (TempData["FunilErroStatus"] != null)
            {
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    @TempData["FunilErroStatus"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
            @if (!abaEspecialIndicadores)
            {
            <div class="mb-3 funil-page-header">
                <div class="funil-title-block">
                    <h1 class="app-page-title mb-0">Prospecções</h1>
                </div>
                <div class="funil-header-tools">
                    <div class="page-utilities">
                        <div class="d-flex gap-2 justify-content-start justify-content-md-end align-items-center funil-header-actions">
                            <!--se a rota não for Index-->
                            @if (!string.IsNullOrEmpty(aba) && !abaEspecialIndicadores)
                            {
                                <form class="table-search-form row gx-1 align-items-center funil-search-form">
                                    <div class="d-flex gap-2 flex-row align-items-center">
                                        <input type="text" id="search-orders" name="SearchString" value="@searchString" class="form-control search-orders" placeholder="Buscar empresa ou projeto..." autocomplete="off">
                                        <button type="submit" class="btn app-btn-primary funil-search-button"><i class="bi bi-search"></i></button>
                                    </div>
                                </form>
                                <button type="submit" class="d-none btn app-btn-primary">Lista Completa</button>
                            }

                            <div class="d-flex gap-2 funil-action-buttons">
                                <a class="btn app-btn-primary" data-bs-toggle="modal" href="#preCriarProspModalToggle" role="button">
                                    <i class="bi bi-plus-circle-fill"></i> Nova Prospecção
                                </a>

                                <a asp-action="ExportarExcel"
                                   asp-controller="FunilDeVendas"
                                   asp-route-casa="@casa"
                                   asp-route-aba="@aba"
                                   class="btn btn-outline-success">
                                    <i class="bi bi-file-earmark-excel"></i> Exportar Excel
                                </a>
                                @await Component.InvokeAsync("ModalPreCreateProsp")
                                @await Component.InvokeAsync("ModalCreateProsp")
                                <div id="modalCreateFollowUpProspContainer"></div>
                            </div>

                            @*<div class="col-auto" id="container-ajuda">
                            <a type="button" class="btn button-flash text-white" data-bs-toggle="modal" href="#modalTutorialFdv" role="button">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-question-octagon-fill" viewBox="0 0 16 16">
                            <path d="M11.46.146A.5.5 0 0 0 11.107 0H4.893a.5.5 0 0 0-.353.146L.146 4.54A.5.5 0 0 0 0 4.893v6.214a.5.5 0 0 0 .146.353l4.394 4.394a.5.5 0 0 0 .353.146h6.214a.5.5 0 0 0 .353-.146l4.394-4.394a.5.5 0 0 0 .146-.353V4.893a.5.5 0 0 0-.146-.353L11.46.146zM5.496 6.033a.237.237 0 0 1-.24-.247C5.35 4.091 6.737 3.5 8.005 3.5c1.396 0 2.672.73 2.672 2.24 0 1.08-.635 1.594-1.244 2.057-.737.559-1.01.768-1.01 1.486v.105a.25.25 0 0 1-.25.25h-.81a.25.25 0 0 1-.25-.246l-.004-.217c-.038-.927.495-1.498 1.168-1.987.59-.444.965-.736.965-1.371 0-.825-.628-1.168-1.314-1.168-.803 0-1.253.478-1.342 1.134-.018.137-.128.25-.266.25h-.825zm2.325 6.443c-.584 0-1.009-.394-1.009-.927 0-.552.425-.94 1.01-.94.609 0 1.028.388 1.028.94 0 .533-.42.927-1.029.927z" />
                            </svg> Tutorial!
                            </a>
                            </div>*@
                        </div>
                    </div>
                </div>

            </div>
            }

            @if (!abaEspecialIndicadores)
            {
            <div class="d-flex align-items-center justify-content-between mb-3 gap-3 funil-filter-row">
                <div class="funil-filter-group">
                <label for="ano">Ano</label>
                <select class="form-select w-auto" id="ano" name="ano" onchange="aplicarFiltrosFunil()">
                    <option value="Todos" selected="@(string.IsNullOrWhiteSpace(anoFiltro) || anoFiltro == "Todos")">Todos</option>
                    @{
                        int anoFinal = 2019;
                        int anoAtual = DateTime.Now.Year;
                        while (anoAtual >= anoFinal)
                        {
                            <option value="@anoAtual" selected="@(anoFiltro == anoAtual.ToString())">@anoAtual</option>
                            anoAtual--;
                        }
                    }
                </select>

                @if (!string.IsNullOrEmpty(aba) && !abaEspecialIndicadores)
                {
                    <label for="temperatura">Temperatura</label>
                    <select class="form-select w-auto funil-filter-select" id="temperatura" name="temperatura" onchange="aplicarFiltrosFunil()">
                        <option value="Todos" selected="@(string.IsNullOrWhiteSpace(temperatura) || temperatura == "Todos")">Todas</option>
                        <option value="quente" selected="@(temperatura == "quente")">Quente</option>
                        <option value="morno" selected="@(temperatura == "morno")">Morno</option>
                        <option value="esfriando" selected="@(temperatura == "esfriando")">Esfriando</option>
                        <option value="frio" selected="@(temperatura == "frio")">Frio</option>
                        <option value="congelado" selected="@(temperatura == "congelado")">Congelado</option>
                    </select>

                    <label for="fomento">Fomento</label>
                    <select class="form-select w-auto funil-filter-select" id="fomento" name="fomento" onchange="aplicarFiltrosFunil()">
                        <option value="Todos" selected="@(string.IsNullOrWhiteSpace(fomento) || fomento == "Todos")">Todos</option>
                        @foreach (TipoContratacao tipoContratacao in Enum.GetValues(typeof(TipoContratacao)))
                        {
                            <option value="@tipoContratacao" selected="@(fomento == tipoContratacao.ToString())">@tipoContratacao.GetDisplayName()</option>
                        }
                    </select>
                    @if (filtrosFunilAtivos)
                    {
                        <button type="button" class="btn btn-outline-secondary funil-clear-filters" onclick="limparFiltrosFunil()">
                            <i class="bi bi-x-circle"></i>
                            Limpar filtros
                        </button>
                    }
                    <div class="d-none">Quantidade de Prospecções:</div>
                    <form class="d-none" method="get" asp-action="Index" asp-controller="FunildeVendas" asp-route-casa="@casa" asp-route-aba="@aba">
                        <select class="form-select" id="tamanhoPagina" onchange="changePageSize()">
                            @if (ViewBag.TamanhoPagina == 21 || ViewBag.TamanhoPagina == null)
                            {
                                <option value="21" selected>21</option>
                            }
                            else
                            {
                                <option value="21">21</option>
                            }

                            @if (ViewBag.TamanhoPagina == 40)
                            {
                                <option value="40" selected>40</option>
                            }
                            else
                            {
                                <option value="40">40</option>
                            }

                            @if (ViewBag.TamanhoPagina == 60)
                            {
                                <option value="60" selected>60</option>
                            }
                            else
                            {
                                <option value="60">60</option>
                            }

                            @if (ViewBag.TamanhoPagina == 100)
                            {
                                <option value="100" selected>100</option>
                            }
                            else
                            {
                                <option value="100">100</option>
                            }
                        </select>
                    </form>
                }
                </div>
                @if (!string.IsNullOrEmpty(aba) && !abaEspecialIndicadores && !abaSegmentos)
                {
                    <div class="funil-view-toolbar">
                        <div class="btn-group" role="group" aria-label="Tipo de visualiza&ccedil;&atilde;o">
                            <button type="button" class="btn btn-outline-primary funil-view-toggle" data-view="funil">
                                <i class="bi bi-filter"></i>
                                Funil
                            </button>
                            <button type="button" class="btn btn-outline-primary funil-view-toggle" data-view="kanban">
                                <i class="bi bi-kanban"></i>
                                Kanban
                            </button>
                            <button type="button" class="btn btn-outline-primary funil-view-toggle" data-view="cards">
                                <i class="bi bi-grid"></i>
                                Cards
                            </button>
                            <button type="button" class="btn btn-outline-primary funil-view-toggle" data-view="tabela">
                                <i class="bi bi-table"></i>
                                Tabela
                            </button>
                        </div>
                    </div>
                }
            </div>

            }

            @if (Model.Prospeccoes.Count() != 0 || qtdProspeccoesPlanejadas > 0 || qtdProspeccoesAtivas > 0 || qtdProspeccoesComProposta > 0 || qtdProspeccoesContratacao > 0 || qtdProspeccoesEncerradas > 0 || abaEspecialIndicadores)
            {
                // abasFunil.Add(new AbaFunil("Dashboard", string.IsNullOrEmpty(aba)));
                abasFunil.Add(new AbaFunil("Planejadas", !string.IsNullOrEmpty(aba) ? aba.ToLowerInvariant() == "planejadas" : false));
                abasFunil.Add(new AbaFunil("Ativas", !string.IsNullOrEmpty(aba) ? aba.ToLowerInvariant() == "ativas" : false));
                abasFunil.Add(new AbaFunil("Com Proposta", !string.IsNullOrEmpty(aba) ? aba.ToLowerInvariant() == "comproposta" : false));
                abasFunil.Add(new AbaFunil("Contratacao", !string.IsNullOrEmpty(aba) ? aba.ToLowerInvariant() == "contratacao" : false));
                abasFunil.Add(new AbaFunil("Encerradas", !string.IsNullOrEmpty(aba) ? aba.ToLowerInvariant() == "encerradas" : false));
                //abasFunil.Add(new AbaFunil("Erradas", !string.IsNullOrEmpty(aba) ? aba.ToLowerInvariant() == "erradas" : false));

                @if (!abaEspecialIndicadores)
                {
                <nav id="orders-table-tab" class="orders-table-tab app-nav-tabs nav shadow-sm flex-column flex-sm-row mb-4">
                    @foreach (var abaFunil in abasFunil)
                    {
                        string classes = "flex-sm-fill text-sm-center nav-link";
                        if (abaFunil.AbaAtiva == true)
                        {
                            classes += " active";
                        }

                        bool condicaoAria = aba.ToLowerInvariant() == abaFunil.RouteAba;
                        int quantidadeAba = abaFunil.RouteAba == "planejadas"
                            ? qtdProspeccoesPlanejadas
                            : abaFunil.RouteAba == "ativas"
                                ? qtdProspeccoesAtivas
                                : abaFunil.RouteAba == "comproposta"
                                    ? qtdProspeccoesComProposta
                                    : abaFunil.RouteAba == "contratacao"
                                        ? qtdProspeccoesContratacao
                                        : qtdProspeccoesEncerradas;
                        string nomeExibicaoAba = abaFunil.RouteAba == "planejadas"
                            ? "Planejadas"
                            : abaFunil.RouteAba == "ativas"
                                ? "Prospecção"
                                : abaFunil.RouteAba == "comproposta"
                                    ? "Em Negociação"
                                    : abaFunil.RouteAba == "contratacao"
                                        ? "Contratação"
                                        : "Encerradas";

                        <a class="@classes"
                           asp-action="@abaFunil.Action"
                           asp-controller="@abaFunil.Controller"
                           asp-route-casa="@casa"
                           asp-route-aba="@abaFunil.RouteAba"
                           asp-route-searchString="@searchString"
                           asp-route-ano="@anoFiltro"
                           asp-route-temperatura="@temperatura"
                           asp-route-fomento="@fomento"
                           aria-selected="@(condicaoAria)">
                            <span class="funil-tab-label">@nomeExibicaoAba</span>
                            <span class="funil-tab-count">@quantidadeAba</span>
                        </a>
                    }
                </nav>
                }
                else
                {
                    <nav class="orders-table-tab app-nav-tabs nav shadow-sm flex-column flex-sm-row mb-4">
                        <a class="flex-sm-fill text-sm-center nav-link @(abaIndicadores ? "active" : "")"
                           asp-action="Index"
                           asp-controller="FunilDeVendas"
                           asp-route-casa="@casa"
                           asp-route-aba="indicadores"
                           asp-route-ano="@ViewBag.Ano">
                            Indicadores
                        </a>
                        @if (usuarioPodeEditarPlanejamentoIndicadores)
                        {
                            <a class="flex-sm-fill text-sm-center nav-link @(abaPlanejamentoIndicadores ? "active" : "")"
                               asp-action="Index"
                               asp-controller="FunilDeVendas"
                               asp-route-casa="@casa"
                               asp-route-aba="planejamento"
                               asp-route-ano="@ViewBag.Ano">
                                Planejamento
                            </a>
                        }
                        <a class="flex-sm-fill text-sm-center nav-link @(abaReceitasIndicadores ? "active" : "")"
                           asp-action="Index"
                           asp-controller="FunilDeVendas"
                           asp-route-casa="@casa"
                           asp-route-aba="receitas"
                           asp-route-ano="@ViewBag.Ano">
                            Receitas
                        </a>
                    </nav>
                }
                <div class="tab-content" id="orders-table-tab-content">
                    @if (abaIndicadores)
                    {
                        <div class="tab-pane fade show active" id="prospeccao-indicadores" role="tabpanel" aria-labelledby="prospeccao-indicadores-tab">
                            <partial name="_IndicadoresMensais" view-data="@ViewData" />
                        </div>
                    }
                    else if (abaPlanejamentoIndicadores)
                    {
                        <div class="tab-pane fade show active" id="indicadores-planejamento" role="tabpanel" aria-labelledby="indicadores-planejamento-tab">
                            <partial name="_PlanejamentoIndicadores" view-data="@ViewData" />
                        </div>
                    }
                    else if (abaReceitasIndicadores)
                    {
                        <div class="tab-pane fade show active" id="indicadores-receitas" role="tabpanel" aria-labelledby="indicadores-receitas-tab">
                            <partial name="_ReceitasGestorIndicadores" view-data="@ViewData" />
                        </div>
                    }
                    else if (string.IsNullOrEmpty(aba))
                    {
                        <div class="tab-pane fade show active" id="prospeccao-dashboard" role="tabpanel" aria-labelledby="prospeccao-dashboard-tab">
                            <div class="app-card app-card-orders-table mb-5">
                                <div class="app-card-body">
                                    <partial name="graph_funil" view-data="@ViewData" />
                                </div>
                            </div>
                        </div>
                    }
                    else if (abaSegmentos)
                    {
                        @await Html.PartialAsync("_SegmentosFunil", Model)
                    }
                    else
                    {
                        @await Html.PartialAsync("ListaProsp", Model)
                    }
                </div>
            }
            else
            {
                <div class="d-flex justify-content-center align-items-center flex-column" style="height: 50vh">
                    <h1 class="bi bi-exclamation-triangle text-warning"></h1>
                    @if (string.IsNullOrEmpty(searchString))
                    {
                        <h2>
                            Página de Prospecções não encontrada.
                        </h2>
                    }
                    else
                    {
                        <h2>
                            Não foram encontradas prospecções com o termo "@searchString".
                        </h2>
                    }
                    <div>Clique <a asp-controller="FunilDeVendas" asp-action="Index" asp-route-tamanhoPagina="@ViewBag.TamanhoPagina" asp-route-casa="@casa" asp-route-aba="@aba" asp-route-ano="@anoFiltro" asp-route-temperatura="@temperatura" asp-route-fomento="@fomento" asp-route-numeroPagina="1">aqui</a> para voltar para a primeira página.</div>
                </div>
            }

            @if (!string.IsNullOrEmpty(aba) && !abaEspecialIndicadores && !abaSegmentos && Model.Pager.TotalPaginas > 1)
            {
                int paginaAtual = Model.Pager.PaginaAtual;
                int totalPaginas = Model.Pager.TotalPaginas;
                int range = 2;

                int inicio = Math.Max(1, paginaAtual - range);
                int fim = Math.Min(totalPaginas, paginaAtual + range);

                <nav class="app-pagination" data-funil-pagination>
                    <ul class="pagination justify-content-center flex-wrap">

                        <!-- Anterior -->
                        <li class="page-item @(Model.Pager.TemPaginaAnterior ? "" : "disabled")">
                            <a class="page-link"
                               asp-controller="FunilDeVendas"
                               asp-action="Index"
                               asp-route-casa="@casa"
                               asp-route-aba="@aba"
                        asp-route-tamanhoPagina="@ViewBag.TamanhoPagina"
                        asp-route-SearchString="@searchString"
                        asp-route-ano="@anoFiltro"
                        asp-route-temperatura="@temperatura"
                        asp-route-fomento="@fomento"
                        asp-route-numeroPagina="@(paginaAtual - 1)">
                                Anterior
                            </a>
                        </li>

                        <!-- Primeira -->
                        @if (inicio > 1)
                        {
                            <li class="page-item">
                                <a class="page-link"
                                   asp-controller="FunilDeVendas"
                                   asp-action="Index"
                                   asp-route-casa="@casa"
                                   asp-route-aba="@aba"
                            asp-route-tamanhoPagina="@ViewBag.TamanhoPagina"
                            asp-route-SearchString="@searchString"
                            asp-route-ano="@anoFiltro"
                            asp-route-temperatura="@temperatura"
                            asp-route-fomento="@fomento"
                            asp-route-numeroPagina="1">
                                    1
                                </a>
                            </li>
                            <li class="page-item disabled">
                                <span class="page-link">…</span>
                            </li>
                        }

                        <!-- Páginas centrais -->
                        @for (int i = inicio; i <= fim; i++)
                        {
                            <li class="page-item @(i == paginaAtual ? "active" : "")">
                                <a class="page-link"
                                   asp-controller="FunilDeVendas"
                                   asp-action="Index"
                                   asp-route-casa="@casa"
                                   asp-route-aba="@aba"
                            asp-route-tamanhoPagina="@ViewBag.TamanhoPagina"
                            asp-route-SearchString="@searchString"
                            asp-route-ano="@anoFiltro"
                            asp-route-temperatura="@temperatura"
                            asp-route-fomento="@fomento"
                            asp-route-numeroPagina="@i">
                                    @i
                                </a>
                            </li>
                        }

                        <!-- Última -->
                        @if (fim < totalPaginas)
                        {
                            <li class="page-item disabled">
                                <span class="page-link">…</span>
                            </li>
                            <li class="page-item">
                                <a class="page-link"
                                   asp-controller="FunilDeVendas"
                                   asp-action="Index"
                                   asp-route-casa="@casa"
                                   asp-route-aba="@aba"
                            asp-route-tamanhoPagina="@ViewBag.TamanhoPagina"
                            asp-route-SearchString="@searchString"
                            asp-route-ano="@anoFiltro"
                            asp-route-temperatura="@temperatura"
                            asp-route-fomento="@fomento"
                            asp-route-numeroPagina="@totalPaginas">
                                    @totalPaginas
                                </a>
                            </li>
                        }

                        <!-- Próxima -->
                        <li class="page-item @(Model.Pager.TemProximaPagina ? "" : "disabled")">
                            <a class="page-link"
                               asp-controller="FunilDeVendas"
                               asp-action="Index"
                               asp-route-casa="@casa"
                               asp-route-aba="@aba"
                        asp-route-tamanhoPagina="@ViewBag.TamanhoPagina"
                        asp-route-SearchString="@searchString"
                        asp-route-ano="@anoFiltro"
                        asp-route-temperatura="@temperatura"
                        asp-route-fomento="@fomento"
                        asp-route-numeroPagina="@(paginaAtual + 1)">
                                Próximo
                            </a>
                        </li>

                    </ul>
                </nav>
            }

        </div>
    </div>
    <partial name="Footer" />
</div>
<script>
    function aplicarFiltrosFunil() {
        const url = new URL(window.location.href);
        const ano = document.getElementById('ano')?.value;
        const temperatura = document.getElementById('temperatura')?.value;
        const fomento = document.getElementById('fomento')?.value;

        if (ano && ano !== 'Todos') {
            url.searchParams.set('ano', ano);
        } else {
            url.searchParams.delete('ano');
        }

        if (temperatura && temperatura !== 'Todos') {
            url.searchParams.set('temperatura', temperatura);
        } else {
            url.searchParams.delete('temperatura');
        }

        if (fomento && fomento !== 'Todos') {
            url.searchParams.set('fomento', fomento);
        } else {
            url.searchParams.delete('fomento');
        }

        url.searchParams.delete('tamanhoPagina');
        url.searchParams.set('numeroPagina', '1');
        window.location.href = url.toString();
    }

    function limparFiltrosFunil() {
        const url = new URL(window.location.href);

        [
            'SearchString',
            'searchString',
            'ano',
            'temperatura',
            'fomento',
            'numeroPagina',
            'tamanhoPagina',
            'sortOrder'
        ].forEach((parametro) => url.searchParams.delete(parametro));

        window.location.href = url.toString();
    }
</script>
