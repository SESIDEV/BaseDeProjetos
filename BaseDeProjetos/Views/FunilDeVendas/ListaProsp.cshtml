                                    <div class="funil-table-team">
                                    @{
                                        var nomeLiderTabela = !string.IsNullOrWhiteSpace(prospeccao.LiderNome) ? prospeccao.LiderNome : prospeccao.Usuario?.UserName;
                                        var apoiadoresTabela = !string.IsNullOrWhiteSpace(prospeccao.MembrosEquipe)
                                            ? prospeccao.MembrosEquipe.Split(";").Where(membro => !string.IsNullOrWhiteSpace(membro)).Select(membro => membro.Trim()).ToList()
                                            : new List<string>();

                                        if (string.IsNullOrWhiteSpace(nomeLiderTabela) && apoiadoresTabela.Any())
                                        {
                                            nomeLiderTabela = apoiadoresTabela.First();
                                            apoiadoresTabela = apoiadoresTabela.Skip(1).ToList();
                                        }
                                        else if (!string.IsNullOrWhiteSpace(nomeLiderTabela))
                                        {
                                            apoiadoresTabela = apoiadoresTabela
                                                .Where(membro => !string.Equals(membro, nomeLiderTabela, StringComparison.OrdinalIgnoreCase))
                                                .ToList();
                                        }
                                    }
                                    @if (!string.IsNullOrWhiteSpace(nomeLiderTabela))
                                    {
