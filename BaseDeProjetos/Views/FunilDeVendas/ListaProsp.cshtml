                                        }
                                    </div>
                                </td> *@
                                <td class="cell text-center">
                                    <button type="button" id="button-@prospeccao.Id" data-bs-target="#detalhes-@prospeccao.Id"
                                            data-bs-toggle="collapse" class="btn funil-details-toggle">
                                        <i class="bi bi-chevron-down"></i>
                                    </button>
                                </td>
