                                            string liderDetalhe = !string.IsNullOrWhiteSpace(prospeccao.LiderNome) ? prospeccao.LiderNome : prospeccao.Usuario != null ? prospeccao.Usuario.UserName : "Sem l&iacute;der";
                                            string tipologiaDetalhe = !string.IsNullOrWhiteSpace(prospeccao.Tipologia) ? prospeccao.Tipologia : "Valor n&atilde;o informado";
                                            string contatoDetalhe = prospeccao.Contato != null && !string.IsNullOrWhiteSpace(prospeccao.Contato.Nome) ? prospeccao.Contato.Nome : "Sem contato informado";
                                        }
                                        <div class="prospeccao-details-shell">
                                            <section class="prospeccao-details-panel prospeccao-details-panel-main">
                                                <div class="prospeccao-details-heading">
                                                    <span>Prospec&ccedil;&atilde;o</span>
                                                    <h3>@prospeccao.NomeProspeccao</h3>
                                                    <p>@prospeccao.Empresa.Nome</p>
                                                </div>
                                                <div class="prospeccao-details-grid">
                                                    <div class="prospeccao-detail-block"><span>ID</span><strong>@prospeccao.Id</strong></div>
                                                    <div class="prospeccao-detail-block"><span>Empresa</span><strong>@prospeccao.Empresa.Nome</strong></div>
                                                    <div class="prospeccao-detail-block"><span>L&iacute;der</span><strong>@Html.Raw(liderDetalhe)</strong></div>
                                                    <div class="prospeccao-detail-block"><span>Origem</span><strong>@prospeccao.Origem.GetDisplayName()</strong></div>
                                                    <div class="prospeccao-detail-block detail-span-2"><span>Linha de pesquisa</span><strong>@prospeccao.LinhaPequisa.GetDisplayName()</strong></div>
                                                    <div class="prospeccao-detail-block"><span>Tipologia</span><strong>@Html.Raw(tipologiaDetalhe)</strong></div>
                                                    <div class="prospeccao-detail-block"><span>Tipo de contrata&ccedil;&atilde;o</span><strong>@prospeccao.TipoContratacao.GetDisplayName()</strong></div>
                                                    <div class="prospeccao-detail-block"><span>Tipo de intera&ccedil;&atilde;o</span><strong>@prospeccao.TipoDeInteracao.GetDisplayName()</strong></div>
                                                    <div class="prospeccao-detail-block"><span>Tipo de projeto</span><strong>@prospeccao.TipoDeProjeto.GetDisplayName()</strong></div>
                                                    <div class="prospeccao-detail-block"><span>Parceiro interno</span><strong>@prospeccao.ParceiroInterno.GetDisplayName()</strong></div>
                                                    <div class="prospeccao-detail-block"><span>Contato</span><strong>@contatoDetalhe</strong></div>
                                                </div>
                                            </section>
                                            <section class="prospeccao-details-panel">
                                                <div class="prospeccao-details-heading compact">
                                                    <span>Valores</span>
                                                    <h3>Financeiro</h3>
                                                </div>
                                                <div class="prospeccao-values-grid">
                                                    <div class="prospeccao-value-block">
                                                        <span>Valor estimado</span>
                                                        @if (prospeccao.ValorEstimado != 0)
                                                        {
                                                            <strong>R$ @Helpers.FormatarValoresDashboards((decimal)prospeccao.ValorEstimado)</strong>
                                                        }
                                                        else
                                                        {
                                                            <strong>Valor n&atilde;o informado</strong>
                                                        }
                                                    </div>
                                                    <div class="prospeccao-value-block">
                                                        <span>Valor proposta</span>
                                                        @if (prospeccao.ValorProposta != 0)
                                                        {
                                                            <strong>R$ @Helpers.FormatarValoresDashboards((decimal)prospeccao.ValorProposta)</strong>
                                                        }
                                                        else
                                                        {
                                                            <strong>Valor n&atilde;o informado</strong>
                                                        }
                                                    </div>
                                                </div>
                                            </section>
                                            <aside class="prospeccao-details-panel prospeccao-details-panel-status">
                                                <div class="prospeccao-status-header">
                                                    <span>Status atual</span>
                                                    <strong>@ultimoStatusDetalhe.Status.GetDisplayName()</strong>
                                                    <small>@ultimoStatusDetalhe.Data.ToString("dd/MM/yyyy", CultureInfo.CreateSpecificCulture("pt-BR"))</small>
                                                </div>
                                                @if (string.IsNullOrWhiteSpace(ultimoStatusDetalhe.Anotacoes))
                                                {
                                                    <p>Sem anota&ccedil;&otilde;es.</p>
                                                }
                                                else
                                                {
                                                    <p>@ultimoStatusDetalhe.Anotacoes</p>
                                                }
                                                <div class="prospeccao-details-actions-panel">
                                                    <a class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" href="#editarProspModal-@prospeccao.Id" role="button" onclick="loadAncora('flexSwitchCheckDefault-@prospeccao.Id', 'iconAncora-@prospeccao.Id', 'campoAgg-@prospeccao.Id')"><i class="bi bi-pencil-square"></i>Editar</a>
                                                    <a class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" href="#historyProspModal-@prospeccao.Id" role="button"><i class="bi bi-clock-history"></i>Hist&oacute;rico</a>
                                                    <a class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" href="#CreateFollowupProspModal-@prospeccao.Id" role="button"><i class="bi bi-plus-circle"></i>Incluir Status</a>
                                                    <a class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" href="#deletarProspModal-@prospeccao.Id" role="button"><i class="bi bi-trash"></i>Deletar</a>
                                                </div>
                                            </aside>
                                        </div>
                                        <h1 class="app-card-title">ID da Prospecção:</h1>
                                        <span>@prospeccao.Id</span>
                                        <h1 class="app-card-title">Empresa:</h1>
                                        <span>@prospeccao.Empresa.Nome</span>
                                        <h1 class="app-card-title">Líder</h1>
                                        @if (!string.IsNullOrWhiteSpace(prospeccao.LiderNome))
                                        {
                                            <span>@prospeccao.LiderNome</span>
                                        }
                                        else if (prospeccao.Usuario != null)
                                        {
                                            <span>@prospeccao.Usuario.UserName</span>
                                        }
                                        else
                                        {
                                            <span>Sem Líder</span>
                                        }
                                        <h1 class="app-card-title">Nome:</h1>
                                        <span>@prospeccao.NomeProspeccao</span>
                                        <h1 class="app-card-title">Origem:</h1>
                                        <span>@prospeccao.Origem.GetDisplayName()</span>
                                        <h1 class="app-card-title">Linha de Pesquisa:</h1>
                                        <span>@prospeccao.LinhaPequisa.GetDisplayName()</span>
                                        <h1 class="app-card-title">Tipologia:</h1>
                                        @if (!string.IsNullOrWhiteSpace(prospeccao.Tipologia))
                                        {
                                            <span>@prospeccao.Tipologia</span>
                                        }
                                        else
                                        {
                                            <span>Valor não informado</span>
                                        }
                                        <h1 class="app-card-title">Valor Estimado:</h1>
                                        <nobr>
                                            @if (prospeccao.ValorEstimado != 0)
                                            {
                                                <span>R$ @Helpers.FormatarValoresDashboards((decimal)prospeccao.ValorEstimado)</span>
                                            }
                                            else
                                            {
                                                <span>Valor não informado</span>
                                            }
                                        </nobr>
                                        <h1 class="app-card-title">Valor Proposta:</h1>
                                        <nobr>
                                            @if (prospeccao.ValorProposta != 0)
                                            {
                                                <span>R$ @Helpers.FormatarValoresDashboards((decimal)prospeccao.ValorProposta)</span>
                                            }
                                            else
                                            {
                                                <span>Valor não informado</span>
                                            }
                                        </nobr>
                                        <div class="prospeccao-status-box">
                                            <div>
                                                <span class="prospeccao-details-kicker">Status atual</span>
                                                <strong>@prospeccao.Status.OrderBy(followup => followup.Data).ThenBy(followup => followup.Id).Last().Status.GetDisplayName()</strong>
                                            </div>
                                            <span class="prospeccao-status-date">
                                                @prospeccao.Status.OrderBy(p => p.Data).ThenBy(p => p.Id).Last().Data.ToString("dd/MM/yyyy", CultureInfo.CreateSpecificCulture("pt-BR"))
                                            </span>
                                            @if (string.IsNullOrWhiteSpace(prospeccao.Status.OrderBy(p => p.Data).ThenBy(p => p.Id).Last().Anotacoes))
                                            {
                                                <p>Sem anota&ccedil;&otilde;es.</p>
                                            }
                                            else
                                            {
                                                <p>@prospeccao.Status.OrderBy(p => p.Data).ThenBy(p => p.Id).Last().Anotacoes</p>
                                            }
                                        </div>
                                        <div class="button-footer prospeccao-details-actions">
                                            <a class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" href="#editarProspModal-@prospeccao.Id"
                                               role="button" onclick="loadAncora('flexSwitchCheckDefault-@prospeccao.Id', 'iconAncora-@prospeccao.Id', 'campoAgg-@prospeccao.Id')">
                                                <i class="bi bi-pencil-square"></i>
                                                Editar
                                            </a>
                                            <a class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" href="#historyProspModal-@prospeccao.Id"
                                               role="button">
                                                Histórico
                                            </a>
                                            <a class="btn btn-outline-primary btn-sm" data-bs-toggle="modal"
                                               href="#CreateFollowupProspModal-@prospeccao.Id" role="button">
                                                <i class="bi bi-plus-circle"></i>
                                                Incluir Status
                                            </a>
                                            <a class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" href="#deletarProspModal-@prospeccao.Id"
                                               role="button">
                                                <i class="bi bi-trash"></i>
                                                Deletar
                                            </a>
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
