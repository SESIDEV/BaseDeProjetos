@using BaseDeProjetos.Helpers
@using BaseDeProjetos.Models
@using BaseDeProjetos.Models.Enums
@{
    string casaIndicadores = ViewBag.Casa as string;
    int anoSelecionado = ViewBag.Ano ?? DateTime.Now.Year;

    var usuarioNivelIndicadores = ViewBag.usuarioNivel;
    var usuarioCasaIndicadoresTexto = (ViewBag.usuarioCasa ?? "").ToString();
    Enum.TryParse(usuarioCasaIndicadoresTexto, out Instituto usuarioCasaIndicadores);
    Enum.TryParse((usuarioNivelIndicadores ?? "").ToString(), out Nivel usuarioNivelIndicadoresEnum);
    var usuarioIndicadores = new Usuario { Casa = usuarioCasaIndicadores, Nivel = usuarioNivelIndicadoresEnum };
    bool usuarioPodeVerTodasCasasIndicadores = FunilHelpers.UsuarioPodeVisualizarTodasCasas(usuarioIndicadores);
    List<Instituto> institutosIndicadores = FunilHelpers.ObterCasasPermitidas(usuarioIndicadores)
        .Where(i => i != Instituto.Super && i != Instituto.ISIII && i != Instituto.ISISVP)
        .ToList();
    bool usuarioPodeSelecionarTodasCasasIndicadores = usuarioPodeVerTodasCasasIndicadores || institutosIndicadores.Count > 1;

    if (string.IsNullOrEmpty(casaIndicadores))
    {
        casaIndicadores = usuarioPodeSelecionarTodasCasasIndicadores && !usuarioPodeVerTodasCasasIndicadores
            ? "Todas"
            : (usuarioPodeVerTodasCasasIndicadores ? Instituto.ISIQV.ToString() : usuarioCasaIndicadores.ToString());
    }

    List<string> casasPermitidasIndicadores = institutosIndicadores
        .Select(instituto => instituto.ToString())
        .ToList();

    if (!usuarioPodeSelecionarTodasCasasIndicadores)
    {
        casaIndicadores = casasPermitidasIndicadores.FirstOrDefault() ?? usuarioCasaIndicadores.ToString();
    }
    else if (!string.Equals(casaIndicadores, "Todas", StringComparison.OrdinalIgnoreCase))
    {
        bool contemCasaNaoPermitida = (casaIndicadores ?? "")
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(c => c.Trim())
            .Any(casaSelecionada => !casasPermitidasIndicadores.Contains(casaSelecionada));

        if (contemCasaNaoPermitida)
        {
            casaIndicadores = usuarioPodeVerTodasCasasIndicadores
                ? Instituto.ISIQV.ToString()
                : "Todas";
        }
    }

    bool todasAsCasasSelecionadas = string.Equals(casaIndicadores, "Todas", StringComparison.OrdinalIgnoreCase);
    List<string> casasSelecionadasIndicadores = (casaIndicadores ?? "")
        .Split(',', StringSplitOptions.RemoveEmptyEntries)
        .Select(c => c.Trim())
        .ToList();
    todasAsCasasSelecionadas = todasAsCasasSelecionadas && usuarioPodeSelecionarTodasCasasIndicadores;
    Dictionary<Instituto, string> nomesCasasIndicadores = new Dictionary<Instituto, string>
    {
        { Instituto.ISIQV, "ISI Química Verde" },
        { Instituto.CISHO, "CIS Saúde Ocupacional" },
        { Instituto.ISIBF_CBT, "ISI B&F CBT" },
        { Instituto.ISIBF_CIN, "ISI B&F CIN" },
        { Instituto.ISIBF_CPQ, "ISI B&F CPQ" },
        { Instituto.ISIBF_CEP, "ISI B&F CEP" },
        { Instituto.ISIBF_CSQ, "ISI B&F CSQ" },
        { Instituto.Servicos_GPD, "Servi\u00e7os GPD" }
    };
}

<script>
    var casa = "@casaIndicadores";
    var anoIndicadores = @anoSelecionado;
</script>

<script src="~/js/FunildeVendas/indicadoresMensais.js" asp-append-version="true"></script>

<style>
    .indicadores-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .indicadores-filtros {
        display: flex;
        align-items: flex-end;
        gap: .75rem;
        flex-wrap: wrap;
        justify-content: flex-end;
    }

    .indicadores-casas-menu {
        min-width: 860px;
        border: 1px solid #ced4da;
        border-radius: .25rem;
        background: #fff;
        padding: .6rem .75rem;
    }

    .indicadores-casas-title {
        display: block;
        font-size: .8rem;
        font-weight: 700;
        margin-bottom: .45rem;
    }

    .indicadores-casas-list {
        display: grid;
        grid-template-columns: repeat(5, minmax(150px, 1fr));
        gap: .25rem .9rem;
    }

    .indicadores-casa-option {
        display: flex;
        align-items: center;
        gap: .35rem;
        margin-bottom: .18rem;
        font-size: .85rem;
        line-height: 1.2;
        white-space: nowrap;
    }

    .indicadores-casa-option:last-child {
        margin-bottom: 0;
    }

    .indicadores-casa-option input {
        margin: 0;
    }

    .indicadores-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(280px, 1fr));
        gap: 1rem;
    }

    .indicadores-card {
        min-height: 360px;
    }

    .indicadores-chart {
        min-height: 320px;
    }


    .indicadores-equipe-card {
        margin-top: 1rem;
        overflow-x: auto;
    }

    .indicadores-equipe-table {
        width: 100%;
        min-width: 920px;
        border-collapse: collapse;
        font-size: .875rem;
        text-align: right;
    }

    .indicadores-equipe-table th {
        background: #0d526b;
        color: #fff;
        font-weight: 700;
        text-align: center;
        white-space: nowrap;
    }

    .indicadores-equipe-table th,
    .indicadores-equipe-table td {
        border: 1px solid #2b2b2b;
        padding: .35rem .55rem;
    }

    .indicadores-equipe-table .equipe-cell {
        color: #111;
        font-weight: 700;
        text-align: center;
        min-width: 130px;
    }

    .indicadores-equipe-table .total-row td {
        background: #0d526b;
        color: #fff;
        font-weight: 700;
    }

    .indicadores-equipe-table .empty-row td {
        text-align: center;
    }

    .indicadores-equipe-table .arraste-input {
        width: 90px;
        border: 1px solid #ced4da;
        border-radius: .2rem;
        padding: .2rem .35rem;
        text-align: right;
        background: #fff;
    }

    .indicadores-equipe-table .arraste-input[readonly] {
        border-color: transparent;
        background: transparent;
        color: inherit;
        cursor: default;
    }

    .indicadores-equipe-table .arraste-input.is-saving {
        background: #fff7d6;
    }

    .indicadores-equipe-table .arraste-input.is-error {
        border-color: #dc3545;
        background: #fff1f1;
    }

    .indicadores-add-pesquisador {
        display: flex;
        gap: .5rem;
        justify-content: flex-end;
        align-items: center;
        margin-bottom: .6rem;
    }

    .indicadores-add-pesquisador .form-select {
        width: min(320px, 100%);
    }

    @@media (max-width: 1200px) {
        .indicadores-grid {
            grid-template-columns: 1fr;
        }
    }

    @@media (max-width: 900px) {
        .indicadores-toolbar {
            align-items: flex-start;
        }

        .indicadores-filtros {
            justify-content: flex-start;
            width: 100%;
        }

        .indicadores-casas-menu {
            min-width: 100%;
        }

        .indicadores-casas-list {
            grid-template-columns: repeat(2, minmax(150px, 1fr));
        }
    }

    @@media (max-width: 560px) {
        .indicadores-casas-list {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="indicadores-toolbar">
    <div>
        <h2 class="app-page-title mb-1">Indicadores</h2>
        <div class="text-muted">Gráficos e Tabelas</div>
    </div>

    <div class="indicadores-filtros">
        <div class="indicadores-casas-menu" id="casaIndicadores">
            <span class="indicadores-casas-title">Casas</span>
            <div class="indicadores-casas-list">
                @if (usuarioPodeSelecionarTodasCasasIndicadores)
                {
                    <label class="indicadores-casa-option" for="casaIndicadoresTodas">
                        <input type="checkbox" name="casasIndicadores" id="casaIndicadoresTodas" value="Todas" checked="@todasAsCasasSelecionadas" />
                        Todas
                    </label>
                }
                @foreach (Instituto instituto in institutosIndicadores)
                {
                    if (!todasAsCasasSelecionadas && casasSelecionadasIndicadores.Contains(instituto.ToString()))
                    {
                        <label class="indicadores-casa-option" for="casaIndicadores-@instituto">
                            <input type="checkbox" name="casasIndicadores" id="casaIndicadores-@instituto" value="@instituto" checked />
                            @(nomesCasasIndicadores.ContainsKey(instituto) ? nomesCasasIndicadores[instituto] : instituto.ToString())
                        </label>
                    }
                    else
                    {
                        <label class="indicadores-casa-option" for="casaIndicadores-@instituto">
                            <input type="checkbox" name="casasIndicadores" id="casaIndicadores-@instituto" value="@instituto" />
                            @(nomesCasasIndicadores.ContainsKey(instituto) ? nomesCasasIndicadores[instituto] : instituto.ToString())
                        </label>
                    }
                }
            </div>
        </div>

        <button type="button" class="btn app-btn-secondary btn-sm" id="aplicarCasasIndicadores">Aplicar</button>

        <label class="form-label mb-0" for="anoIndicadoresSelect">Ano</label>
        <select class="form-select w-auto" id="anoIndicadoresSelect">
            @for (int ano = DateTime.Now.Year; ano >= 2019; ano--)
            {
                if (ano == anoSelecionado)
                {
                    <option value="@ano" selected>@ano</option>
                }
                else
                {
                    <option value="@ano">@ano</option>
                }
            }
        </select>
    </div>
</div>

<div class="indicadores-grid">
    <div class="app-card app-card-chart shadow-sm indicadores-card">
        <div id="grafico-contatos" class="indicadores-chart"><partial name="_Loading" /></div>
    </div>

    <div class="app-card app-card-chart shadow-sm indicadores-card">
        <div id="grafico-propostas" class="indicadores-chart"><partial name="_Loading" /></div>
    </div>

    <div class="app-card app-card-chart shadow-sm indicadores-card">
        <div id="grafico-convertidas" class="indicadores-chart"><partial name="_Loading" /></div>
    </div>
</div>
<div class="app-card shadow-sm indicadores-equipe-card">
    @Html.AntiForgeryToken()
    <div id="tabela-equipe-indicadores"><partial name="_Loading" /></div>
    <div class="mt-3" id="tabela-taxas-indicadores"><partial name="_Loading" /></div>
    <div class="mt-3" id="tabela-contatos-pesquisador-indicadores"><partial name="_Loading" /></div>
</div>
