@model BaseDeProjetos.Models.Prospeccao
@using BaseDeProjetos.Models.Enums
@using Microsoft.AspNetCore.Http
@using BaseDeProjetos.Models
@using BaseDeProjetos.Models.DTOs

@{
    ViewData["Title"] = "Adicionar Prospecção";

    if (Context.Session.GetString("_Casa") != null)
    {
        ViewData["Area"] = Context.Session.GetString("_Casa");
    }

    var unique_id = $"prosp_{DateTime.Now.Ticks}";
}

<script src="~/js/FunildeVendas/modalCreateProsp.js" asp-append-version="true"></script>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="modal fade" id="criarProspModalToggle" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title fw-semibold">NOVA PROSPECÇÃO</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">

                    <input asp-for="Id" type="hidden" value="@unique_id" />

                    <div class="card mb-3">
                        <div class="card-header fw-semibold">PROJETO</div>
                        <div class="card-body">
                            <div class="row g-3">

                                <div class="col-md-8">
                                    <label asp-for="NomeProspeccao" class="form-label fw-semibold">
                                        Nome da prospecção <span class="text-danger">*</span>
                                    </label>

                                    <input asp-for="NomeProspeccao"
                                           class="form-control"
                                           placeholder="Ex.: Proposta de biossurfactantes" required/>

                                    <span asp-validation-for="NomeProspeccao" class="text-danger"></span>
                                </div>


                                <div class="col-md-4">
                                    <label asp-for="Casa" class="form-label fw-semibold">Casa</label>
                                    @if (Context.Session.GetString("_Casa") != null)
                                    {
                                        var enumCasa = (int)Enum.Parse(typeof(Instituto),
                                        Context.Session.GetString("_Casa"), true);

                                        <select asp-for="Casa" class="form-select">
                                            <option value="@enumCasa">@Context.Session.GetString("_Casa")</option>
                                        </select>
                                    }
                                    else
                                    {
                                        <select asp-for="Casa" class="form-select"
                                                asp-items="Html.GetEnumSelectList<Instituto>()"></select>
                                    }
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="Tipologia" class="form-label fw-semibold">
                                        Tipologia <span class="text-danger">*</span>
                                    </label>
                                     
                                    <select asp-for="Tipologia" class="form-select" required>
                                        <option value="">Selecione</option>
                                        <option value="A">A</option>
                                        <option value="B">B</option>
                                        <option value="C">C</option>
                                        <option value="D">D</option>
                                        <option value="A definir">A definir</option>
                                    </select>

                                    <span asp-validation-for="Tipologia" class="text-danger"></span>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="TipoDeInteracao" class="form-label fw-semibold">
                                        Tipo de interação <span class="text-danger">*</span>
                                    </label>

                                    <select asp-for="TipoDeInteracao"
                                            class="form-select"
                                            asp-items="Html.GetEnumSelectList<TipoDeInteracao>()" required>
                                        <option value="">Selecione</option>
                                    </select>

                                    <span asp-validation-for="TipoDeInteracao" class="text-danger"></span>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="TipoDeProjeto" class="form-label fw-semibold">
                                        Tipo de projeto <span class="text-danger">*</span>
                                    </label>

                                    <select asp-for="TipoDeProjeto"
                                            class="form-select"
                                            asp-items="Html.GetEnumSelectList<TipoDeProjeto>()" required>
                                        <option value="">Selecione</option>
                                    </select>

                                    <span asp-validation-for="TipoDeProjeto" class="text-danger"></span>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="PrevisaoTempoProjetoMeses" class="form-label fw-semibold">
                                        Previsão de tempo (meses)
                                    </label>

                                    <input asp-for="PrevisaoTempoProjetoMeses"
                                           class="form-control"
                                           type="number"
                                           min="0"
                                           step="1"
                                           placeholder="Ex.: 12" />

                                    <span asp-validation-for="PrevisaoTempoProjetoMeses" class="text-danger"></span>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="Origem" class="form-label fw-semibold">
                                        Iniciativa da prospecção <span class="text-danger">*</span>
                                    </label>

                                    <select asp-for="Origem"
                                            class="form-select"
                                            asp-items="Html.GetEnumSelectList<Origem>()" required>
                                        <option value="">Selecione</option>
                                    </select>

                                    <span asp-validation-for="Origem" class="text-danger"></span>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="TipoContratacao" class="form-label fw-semibold">
                                        Tipo de contratação <span class="text-danger">*</span>
                                    </label>

                                    <select asp-for="TipoContratacao"
                                            class="form-select"
                                            asp-items="Html.GetEnumSelectList<TipoContratacao>()" required>
                                        <option value="">Selecione</option>
                                    </select>

                                    <span asp-validation-for="TipoContratacao" class="text-danger"></span>
                                </div>


                                <div class="col-md-4">
                                    <label asp-for="LinhaPequisa" class="form-label fw-semibold">
                                        Linha de pesquisa <span class="text-danger">*</span>
                                    </label>

                                    <select asp-for="LinhaPequisa"
                                            class="form-select"
                                            asp-items="Html.GetEnumSelectList<LinhaPesquisa>()" required>
                                        <option value="">Selecione</option> 
                                    </select>

                                    <span asp-validation-for="LinhaPequisa" class="text-danger"></span>
                                </div>

                            </div>
                        </div>
                    </div>

                    <div class="card mb-3">
                        <div class="card-header fw-semibold">EMPRESA</div>
                        <div class="card-body">
                            <input type="hidden" id="CadastrarNovaEmpresa" name="CadastrarNovaEmpresa" value="false" />

                            <div id="opcoesEmpresaNaoPlanejada" class="mb-3">
                                <label class="form-label fw-semibold">Como deseja informar a empresa?</label>
                                <div class="d-flex flex-column flex-md-row gap-3">
                                    <div class="form-check">
                                        <input class="form-check-input"
                                               type="radio"
                                               name="TipoCadastroEmpresa"
                                               id="tipoEmpresaCadastrada"
                                               value="cadastrada"
                                               checked />
                                        <label class="form-check-label" for="tipoEmpresaCadastrada">
                                            Selecionar empresa cadastrada
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input"
                                               type="radio"
                                               name="TipoCadastroEmpresa"
                                               id="tipoEmpresaNova"
                                               value="nova" />
                                        <label class="form-check-label" for="tipoEmpresaNova">
                                            Cadastrar nova empresa
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <div class="row g-3">
                                <div class="col-md-6" id="empresaCadastradaFields">
                                    <label class="form-label fw-semibold" for="EmpresaInput">Empresa <span class="text-danger">*</span></label>
                                    <input id="EmpresaInput" class="form-control" list="empresas" placeholder="Digite o nome da empresa ou selecione" autocomplete="off" />
                                    <datalist id="empresas">
                                        @{
                                            var empresasSelect = ViewData["Empresas"] as SelectList;
                                            if (empresasSelect != null)
                                            {
                                                foreach (Microsoft.AspNetCore.Mvc.Rendering.SelectListItem e in empresasSelect)
                                                {
                                                    <option data-id="@e.Value" value="@e.Text"></option>
                                                }
                                            }
                                        }
                                    </datalist>

                                    <!-- Campo ligado ao modelo: obrigatório para o binder enviar o id -->
                                    <input asp-for="EmpresaId" type="hidden" id="EmpresaId" />

                                    <span asp-validation-for="EmpresaId" class="text-danger"></span>
                                </div>

                                <div class="col-12 d-none" id="novaEmpresaFields">
                                    <div class="row g-3">
                                        <div class="col-md-6">
                                            <label class="form-label fw-semibold" for="NovaEmpresa_Nome">
                                                Nome fantasia <span class="text-danger">*</span>
                                            </label>
                                            <input id="NomeEmpresa-prosp"
                                                   name="NovaEmpresa.Nome"
                                                   class="form-control nova-empresa-field"
                                                   disabled />
                                        </div>

                                        <div class="col-md-6">
                                            <label class="form-label fw-semibold" for="NovaEmpresa_RazaoSocial">
                                                Razão social
                                            </label>
                                            <input id="RazaoSocialEmpresaCadastro-prosp"
                                                   name="NovaEmpresa.RazaoSocial"
                                                   class="form-control nova-empresa-field"
                                                   readonly
                                                   disabled />
                                        </div>

                                        <div class="col-md-4">
                                            <label class="form-label fw-semibold" for="valor_cnpj-prosp">
                                                CNPJ <span class="text-danger">*</span>
                                            </label>
                                            <div class="input-group">
                                                <input id="valor_cnpj-prosp"
                                                       name="NovaEmpresa.CNPJ"
                                                       class="form-control nova-empresa-field"
                                                       maxlength="18"
                                                       placeholder="00.000.000/0000-00"
                                                       onkeypress="$(this).mask('00.000.000/0000-00')"
                                                       disabled />
                                                <button class="btn app-btn-primary"
                                                        onclick="checarCNPJProspeccao()"
                                                        type="button">
                                                    Buscar
                                                </button>
                                            </div>
                                            <p id="StatusCNPJ-prosp" class="mb-1"></p>
                                            <small id="TipoEmpresaStatus-prosp" class="d-block text-muted">Tipo:</small>
                                            <small id="SituacaoEmpresaStatus-prosp" class="d-block text-muted">Situação:</small>
                                        </div>

                                        <div class="col-md-4">
                                            <label class="form-label fw-semibold" for="NovaEmpresa_Porte">Porte</label>
                                            <input id="PorteEmpresaCadastro-prosp"
                                                   name="NovaEmpresa.Porte"
                                                   class="form-control nova-empresa-field"
                                                   disabled />
                                        </div>

                                        <div class="col-md-4">
                                            <label class="form-label fw-semibold" for="NovaEmpresa_Segmento">Segmento</label>
                                            <select id="NovaEmpresa_Segmento"
                                                    name="NovaEmpresa.Segmento"
                                                    class="form-select nova-empresa-field"
                                                    asp-items="Html.GetEnumSelectList<SegmentoEmpresa>()"
                                                    disabled>
                                            </select>
                                        </div>

                                        <div class="col-md-4">
                                            <label class="form-label fw-semibold" for="EstadoEmpresaCadastro-prosp">Estado</label>
                                            <input id="EstadoEmpresaCadastro-prosp"
                                                   class="form-control nova-empresa-field"
                                                   readonly
                                                   disabled />
                                            <input id="EstadoEmpresaCadastroINT-prosp"
                                                   name="NovaEmpresa.Estado"
                                                   value="0"
                                                   type="hidden"
                                                   class="nova-empresa-field"
                                                   disabled />
                                        </div>

                                        <div class="col-md-4 d-flex align-items-end">
                                            <div class="mb-2">
                                                <span class="fw-semibold">CNAE Industrial:</span>
                                                <i id="checkCNAE-prosp"
                                                   class="fa"
                                                   style="display:none; margin-left: 6px;"></i>
                                                <input id="BoolCnaeIndustrial-prosp"
                                                       name="NovaEmpresa.Industrial"
                                                       value="false"
                                                       type="hidden"
                                                       class="nova-empresa-field"
                                                       disabled />
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                    
                                <div class="col-md-6">
                                    <label asp-for="Contato.Nome" class="form-label fw-semibold">
                                        Nome do contato <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="Contato.Nome" class="form-control" required/>
                                    <span asp-validation-for="Contato.Nome" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Contato.Cargo" class="form-label fw-semibold">
                                        Cargo do contato <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="Contato.Cargo" class="form-control" required/>
                                    <span asp-validation-for="Contato.Cargo" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Contato.Telefone" class="form-label fw-semibold">
                                        Telefone de contato <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="Contato.Telefone"
                                           class="form-control"
                                           onkeypress="$(this).mask('(00) 0000-00009')"
                                           placeholder="(xx) xxxxx-xxxx" required/>
                                    <span asp-validation-for="Contato.Telefone" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Contato.Email" class="form-label fw-semibold">
                                        E-mail de contato <span class="text-danger">*</span>
                                    </label>
                                    <input asp-for="Contato.Email"
                                           class="form-control"
                                           type="email" required/>
                                    <span asp-validation-for="Contato.Email" class="text-danger"></span>
                                </div>


                            </div>
                        </div>
                    </div>

                    <div class="card mb-3">
                        <div class="card-header fw-semibold">EQUIPE</div>
                        <div class="card-body">

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold" for="liderProjeto">
                                    Líder <span class="text-danger">*</span>
                                </label>
                                <input id="liderProjeto"
                                       name="LiderNome"
                                       class="form-control"
                                       list="lideresProjeto"
                                       placeholder="Digite o nome do líder"
                                       autocomplete="off"
                                       required />
                                <datalist id="lideresProjeto">
                                    @{
                                        var pessoasApoioLider = ViewData["PessoasApoio"] as List<PessoaModel>;
                                        if (pessoasApoioLider != null && pessoasApoioLider.Any())
                                        {
                                            foreach (var p in pessoasApoioLider
                                                .Where(p => p.Cargo == "Pesquisador" || p.Cargo == "Coordenador")
                                                .OrderBy(p => p.Nome))
                                            {
                                                var value = (p.Nome ?? "")
                                                    .Split(new char[] { ',', ';' })[0]
                                                    .Trim();

                                                <option value="@value">
                                                    @p.Nome (@p.Cargo) - @p.Casa [@p.Situacao]
                                                </option>
                                            }
                                        }
                                    }
                                </datalist>
                            </div>

                            <div class="mb-6">
                                <label class="col-form-label" style="font-weight: 600" for="inputTextPessoas">Membros</label>
                                <div style="margin-left:3%;display:none" class="spinner-border" role="status" id="loadingOpcoesSelectPessoas">
                                    <span class="visually-hidden">Loading...</span>
                                </div>
                                <input asp-for="MembrosEquipe" class="form-control d-none" id="inputTextPessoas" type="text" />
                                <button class="btn app-btn-primary" type="button" style="width: 100%;" id="botaoToggleCaixaRequestPessoas" onclick="gerarOpcoesSelect('Pessoas', 'criarProspModalToggle')">Buscar</button>
                                <div class="input-group flex-nowrap" id="caixaPesquisaPessoas" style="display:block;">
                                    <select id="campoSelectPessoas" class="form-select" multiple="true">
                                        @{
                                            var pessoas = ViewData["PessoasApoio"] as List<PessoaModel>;
                                            if (pessoas != null && pessoas.Any())
                                            {
                                                foreach (var p in pessoas
                                                .Where(p => p.Cargo == "Pesquisador" || p.Cargo == "Coordenador"))
                                                {
                                                    var value = (p.Nome ?? "")
                                                    .Split(new char[] { ',', ';' })[0]
                                                    .Trim();

                                                    <option value="@value"
                                                            data-cargo="@p.Cargo"
                                                            data-casa="@p.Casa"
                                                            data-situacao="@p.Situacao">
                                                        @p.Nome (@p.Cargo) - @p.Casa [@p.Situacao]
                                                    </option>
                                                }
                                            }
                                            else
                                            {
                                                <option disabled>Arquivo apoio.csv não encontrado ou vazio</option>
                                            }

                                        }
                                    </select>
                                </div>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="PotenciaisParceiros" class="form-label fw-semibold"> Potenciais Parceiros</label>
                                <input asp-for="PotenciaisParceiros" class="form-control" />
                            </div>

                            <div class="col-md-6">
                                <label class="form-label fw-semibold" for="ParceiroInterno">
                                    Parceiros internos <span class="text-danger">*</span>
                                </label>

                                <select asp-for="ParceiroInterno"
                                        class="form-select"
                                        asp-items="Html.GetEnumSelectList<ParceiroInterno>()" required>
                                    <option value="">Selecione</option>
                                </select>

                                <span asp-validation-for="ParceiroInterno" class="text-danger"></span>
                            </div>
                            @*<div class="mb-3">
                                <label asp-for="Tags" class="form-label fw-semibold"></label>
                                <div class="input-group">
                                    <input asp-for="Tags" class="form-control" id="tagsText" />
                                    <button class="btn app-btn-primary" type="button"
                                            onclick="gerarOpcoesSelect('Tags', 'criarProspModalToggle')">
                                        Adicionar
                                    </button>
                                </div>
                            </div>*@

                        </div>
                    </div>

                    <div class="card mb-3">
                        <div class="card-header fw-semibold">STATUS<br> INICIAL</div>
                        <div class="card-body">
                            <div class="row g-3">
                                <input asp-for="Status[0].Data" type="hidden" />
                                <input asp-for="Status[0].Status" type="hidden" value="@StatusProspeccao.ContatoInicial" />

                                <div class="col-md-6">
                                    <label asp-for="Status[0].Anotacoes" class="form-label fw-semibold">Observações e anotações</label>
                                    <textarea asp-for="Status[0].Anotacoes"
                                              class="form-control"
                                              rows="3"></textarea>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Status[0].Status" class="form-label fw-semibold">Status</label>
                                    <select class="form-select" disabled>
                                        <option value="@StatusProspeccao.ContatoInicial">
                                            Contato Inicial
                                        </option>
                                        <option value="@StatusProspeccao.Planejada">
                                            Planejada
                                        </option>
                                    </select>
                                </div>

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">Identificador</label>
                                    <input class="form-control" value="@unique_id" disabled />
                                </div>

                            </div>
                        </div>
                    </div>

                </div>

                <!-- FOOTER -->
                <div class="modal-footer">
                    <button type="button" class="btn app-btn-secondary" data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn app-btn-primary">
                        Concluir
                    </button>
                </div>

            </div>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        (function () {
            var select = document.getElementById('campoSelectPessoas');
            var hidden = document.getElementById('inputTextPessoas');
            var form = document.querySelector('form[asp-action="Create"]') || document.querySelector('form');

            if (form) {
                form.addEventListener('submit', function () {
                    if (select && hidden) {
                        var values = Array.from(select.selectedOptions).map(function (o) { return o.value; });
                        // armazena em formato ponto-e-vírgula; ajustável conforme necessidade
                        hidden.value = values.join(';');
                    }
                });
            }
        })();
    </script>
}
