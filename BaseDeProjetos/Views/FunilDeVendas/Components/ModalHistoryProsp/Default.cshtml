@model BaseDeProjetos.Models.Prospeccao
@using BaseDeProjetos.Models.Enums;
@using Microsoft.AspNetCore.Http
@using System.Globalization

@{
    ViewData["Title"] = "Detalhes";
    if (!(Context.Session.GetString("_Casa") is null))
    {
        ViewData["Area"] = Context.Session.GetString("_Casa");
    }

    var gruposStatus = Model.Status
        .OrderBy(s => s.Data)
        .ThenBy(s => s.Id)
        .GroupBy(s => s.Status)
        .Select(grupo => new
        {
            Status = grupo.Key,
            Followups = grupo.OrderBy(s => s.Data).ThenBy(s => s.Id).ToList(),
            Primeiro = grupo.OrderBy(s => s.Data).ThenBy(s => s.Id).First()
        })
        .OrderBy(grupo => grupo.Primeiro.Data)
        .ThenBy(grupo => grupo.Primeiro.Id)
        .ToList();
}
@foreach (var followup in Model.Status.OrderBy(s => s.Data).ThenBy(s => s.Id).ToList())
{
    @await Component.InvokeAsync("ModalEditFollowupProsp", new { id = Model.Id, id2 = followup.Id })
}


<div class="modal fade" id="historyProspModal-@Model.Id" tabindex="-1"
     aria-labelledby="historyProspModal-@Model.Id-Label" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="historyProspModal-@Model.Id">Hist&oacute;rico de Atualiza&ccedil;&otilde;es</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="accordion" id="accordionPanelsFollowups">
                    @foreach (var grupoStatus in gruposStatus)
                    {
                        var idGrupo = $"{Model.Id}-{grupoStatus.Primeiro.Id}-{(int)grupoStatus.Status}";
                        <div class="accordion-item funil-history-status-group">
                            <h2 class="accordion-header" id="panelsFollowups-heading-@idGrupo">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#panelsFollowups-collapse-@idGrupo" aria-expanded="true"
                                        aria-controls="panelsFollowups-collapse-@idGrupo">
                                    <div class="funil-history-status-title">
                                        <strong>
                                            @grupoStatus.Primeiro.Data.ToString("dd/MM/yyyy", CultureInfo.CreateSpecificCulture("pt-BR")) - @grupoStatus.Status.GetDisplayName()
                                        </strong>
                                        @if (grupoStatus.Followups.Count > 1)
                                        {
                                            <span>@grupoStatus.Followups.Count anota&ccedil;&otilde;es</span>
                                        }
                                    </div>
                                </button>
                            </h2>
                            <div id="panelsFollowups-collapse-@idGrupo" class="accordion-collapse collapse"
                                 aria-labelledby="panelsFollowups-heading-@idGrupo">
                                <div class="accordion-body">
                                    <div class="funil-history-notes">
                                        @foreach (var followup in grupoStatus.Followups)
                                        {
                                            <div class="funil-history-note">
                                                <div class="funil-history-note-header">
                                                    <strong>@followup.Data.ToString("dd/MM/yyyy", CultureInfo.CreateSpecificCulture("pt-BR"))</strong>
                                                    <span>Vence em: @followup.Vencimento.ToString("dd/MM/yyyy", CultureInfo.CreateSpecificCulture("pt-BR"))</span>
                                                </div>

                                                @if (string.IsNullOrEmpty(followup.Anotacoes))
                                                {
                                                    <p>N&atilde;o h&aacute; nada preenchido.</p>
                                                }
                                                else
                                                {
                                                    <p>@followup.Anotacoes</p>
                                                }

                                                <div class="funil-history-note-actions">
                                                    @if (followup.Status != StatusProspeccao.ContatoInicial)
                                                    {
                                                        <a class="btn btn-outline-danger btn-sm" asp-controller="FunilDeVendas" asp-action="RemoverFollowUp" asp-route-id="@followup.Id">Remover</a>
                                                    }
                                                    <button type="button" class="btn app-btn-secondary btn-sm" data-bs-toggle="modal"
                                                            data-bs-target="#EditFollowupProspModal-@followup.Id">
                                                        Editar
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                    @if (grupoStatus.Followups.Count > 1)
                                    {
                                        <small class="funil-history-group-help">Este status aparece uma &uacute;nica vez no hist&oacute;rico; as entradas antigas foram agrupadas como anota&ccedil;&otilde;es.</small>
                                    }
                                    <!-- O Model ID aqui se refere a prospeccao, é extremamente importante que esses IDs batam assim como no ViewComponent, caso o bootstrap alegue undefined para o backdrop, tente verificar esses dois IDs -->
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn app-btn-secondary" data-bs-target="#modalDetalhes-@Model.Id"
                        data-bs-toggle="modal">
                    Voltar
                </button>
                <button type="button" class="btn app-btn-primary" data-bs-dismiss="modal">Sair</button>
            </div>
        </div>
    </div>
</div>
