@model BaseDeProjetos.Models.Prospeccao
@using BaseDeProjetos.Models
@using BaseDeProjetos.Models.DTOs
@using BaseDeProjetos.Models.Enums;
@using Microsoft.AspNetCore.Http
@using System.Globalization

@{
    ViewData["Title"] = "Edit";
    if (Context.Session.GetString("_Casa") != null)
    {
        ViewData["Area"] = Context.Session.GetString("_Casa");
    }
}

<div class="modal fade"
     id="editarProspModal-@Model.Id"
     tabindex="-1"
     aria-hidden="true">

    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">

            <form asp-action="Edit" asp-route-id="@Model.Id" method="post">

                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <!-- HEADER -->
                <div class="modal-header">
                    <h5 class="modal-title fw-semibold">Editar prospecção</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <!-- BODY -->
                <div class="modal-body">

                    <ul class="nav nav-tabs mb-3">
                        <li class="nav-item">
                            <button class="nav-link active" data-bs-toggle="tab"
                                    data-bs-target="#tab-projeto-@Model.Id" type="button">
                                Projeto
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" data-bs-toggle="tab"
                                    data-bs-target="#tab-empresa-@Model.Id" type="button">
                                Empresa
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link"
                                    data-bs-toggle="tab"
                                    data-bs-target="#tab-equipe-@Model.Id"
                                    type="button">
                                Equipe
                            </button>
                        </li>
                        <li class="nav-item">
                            <button class="nav-link" data-bs-toggle="tab"
                                    data-bs-target="#tab-valores-@Model.Id" type="button">
                                Valores
                            </button>
                        </li>
                    </ul>

                    <div class="tab-content">

                        <!-- PROJETO -->
                        <div class="tab-pane fade show active" id="tab-projeto-@Model.Id">
                            <div class="row g-3">

                                <div class="col-md-4">
                                    <label class="form-label fw-semibold">ID</label>
                                    <input class="form-control" value="@Model.Id" disabled />
                                </div>

                                <div class="col-md-8">
                                    <label asp-for="NomeProspeccao" class="form-label fw-semibold">
                                        @Html.DisplayNameFor(m => m.NomeProspeccao) <span class="text-danger">*</span>
                                    </label>

                                    <input asp-for="NomeProspeccao" class="form-control" required />
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="Casa" class="form-label fw-semibold">Casa</label>
                                    <input type="hidden" asp-for="Casa" value="@((int)Model.Casa)" />
                                    <input class="form-control" value="@Model.Casa" readonly />
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="Tipologia" class="form-label fw-semibold">
                                        @Html.DisplayNameFor(m => m.Tipologia) <span class="text-danger">*</span>
                                    </label>

                                    <select asp-for="Tipologia" class="form-select" required>
                                        <option value="">Selecione</option>
                                        <option>A</option>
                                        <option>B</option>
                                        <option>C</option>
                                        <option>D</option>
                                        <option>A definir</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="TipoDeInteracao" class="form-label fw-semibold">
                                        @Html.DisplayNameFor(m => m.TipoDeInteracao) <span class="text-danger">*</span>
                                    </label>

                                    <select asp-for="TipoDeInteracao"
                                            class="form-select"
                                            asp-items="Html.GetEnumSelectList<TipoDeInteracao>()"
                                            required>
                                        <option value="">Selecione</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="TipoDeProjeto" class="form-label fw-semibold">
                                        @Html.DisplayNameFor(m => m.TipoDeProjeto) <span class="text-danger">*</span>
                                    </label>

                                    <select asp-for="TipoDeProjeto"
                                            class="form-select"
                                            asp-items="Html.GetEnumSelectList<TipoDeProjeto>()"
                                            required>
                                        <option value="">Selecione</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="Origem" class="form-label fw-semibold">
                                        @Html.DisplayNameFor(m => m.Origem) <span class="text-danger">*</span>
                                    </label>

                                    <select asp-for="Origem"
                                            class="form-select"
                                            asp-items="Html.GetEnumSelectList<Origem>()"
                                            required>
                                        <option value="">Selecione</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="TipoContratacao" class="form-label fw-semibold">
                                        @Html.DisplayNameFor(m => m.TipoContratacao) <span class="text-danger">*</span>
                                    </label>

                                    <select asp-for="TipoContratacao"
                                            class="form-select"
                                            asp-items="Html.GetEnumSelectList<TipoContratacao>()"
                                            required>
                                        <option value="">Selecione</option>
                                    </select>
                                </div>


                                <div class="col-md-6">
                                    <label asp-for="LinhaPequisa" class="form-label fw-semibold">
                                        @Html.DisplayNameFor(m => m.LinhaPequisa) <span class="text-danger">*</span>
                                    </label>

                                    <select asp-for="LinhaPequisa"
                                            class="form-select"
                                            asp-items="Html.GetEnumSelectList<LinhaPesquisa>()"
                                            required>
                                        <option value="">Selecione</option>
                                    </select>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="PrevisaoTempoProjetoMeses" class="form-label fw-semibold">
                                        Previsão de tempo (meses)
                                    </label>

                                    <input asp-for="PrevisaoTempoProjetoMeses"
                                           class="form-control"
                                           type="number"
                                           min="0"
                                           step="1"
                                           placeholder="Ex.: 12" />

                                    <span asp-validation-for="PrevisaoTempoProjetoMeses" class="text-danger"></span>
                                </div>

                                <div class="col-md-8">
                                    <label asp-for="LinkArquivo" class="form-label fw-semibold">
                                        Link para pasta ou documento do projeto
                                    </label>

                                    <input asp-for="LinkArquivo"
                                           class="form-control"
                                           type="text"
                                           placeholder="Cole o link da pasta ou documento do projeto" />

                                    <span asp-validation-for="LinkArquivo" class="text-danger"></span>
                                </div>


                            </div>
                        </div>

                        <!-- EMPRESA -->
                        <div class="tab-pane fade" id="tab-empresa-@Model.Id">
                            <div class="row g-3">

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="EmpresaInput-@Model.Id">
                                        @Html.DisplayNameFor(m => m.EmpresaId) <span class="text-danger">*</span>
                                    </label>

                                    <input id="EmpresaInput-@Model.Id"
                                           class="form-control"
                                           list="empresas-@Model.Id"
                                           placeholder="Digite o nome da empresa ou selecione"
                                           autocomplete="off"
                                           value="@(Model.Empresa?.Nome ?? "")" />

                                    <datalist id="empresas-@Model.Id">
                                        @{
                                            var empresasSelect = ViewData["Empresas"] as SelectList;
                                            if (empresasSelect != null)
                                            {
                                                foreach (Microsoft.AspNetCore.Mvc.Rendering.SelectListItem e in empresasSelect)
                                                {
                                                    <option data-id="@e.Value" value="@e.Text"></option>
                                                }
                                            }
                                        }
                                    </datalist>

                                    <!-- hidden ligado ao modelo; id com sufixo para o mapeador JS -->
                                    <input asp-for="EmpresaId" type="hidden" id="EmpresaId-@Model.Id" />

                                    <span asp-validation-for="EmpresaId" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Contato.Nome" class="form-label fw-semibold">
                                        @Html.DisplayNameFor(m => m.Contato.Nome) <span class="text-danger">*</span>
                                    </label>

                                    <input asp-for="Contato.Nome" class="form-control" required />
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="Contato.Cargo" class="form-label fw-semibold">
                                        @Html.DisplayNameFor(m => m.Contato.Cargo) <span class="text-danger">*</span>
                                    </label>

                                    <input asp-for="Contato.Cargo" class="form-control" required />
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="Contato.Telefone" class="form-label fw-semibold">
                                        @Html.DisplayNameFor(m => m.Contato.Telefone) <span class="text-danger">*</span>
                                    </label>

                                    <input asp-for="Contato.Telefone" class="form-control"
                                           onkeypress="$(this).mask('(00) 0000-00009')" required />
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="Contato.Email" class="form-label fw-semibold">
                                        @Html.DisplayNameFor(m => m.Contato.Email) <span class="text-danger">*</span>
                                    </label>

                                    <input asp-for="Contato.Email" class="form-control" type="email" required />
                                </div>

                            </div>
                        </div>

                        <!-- EQUIPE -->
                        <div class="tab-pane fade" id="tab-equipe-@Model.Id">
                            <div class="row g-3">

                                <div class="col-md-6">
                                    <label class="form-label fw-semibold" for="UsuarioId-@Model.Id">
                                        L&iacute;der <span class="text-danger">*</span>
                                    </label>
                                    <input id="liderProjeto-@Model.Id"
                                           name="LiderNome"
                                           class="form-control"
                                           list="lideresProjeto-@Model.Id"
                                           placeholder="Digite o nome do l&iacute;der"
                                           autocomplete="off"
                                           value="@(Model.LiderNome ?? Model.Usuario?.UserName ?? "")"
                                           required />
                                    <datalist id="lideresProjeto-@Model.Id">
                                        @{
                                            var pessoasApoioLiderInputEdit = ViewData["PessoasApoio"] as List<PessoaModel>;
                                            if (pessoasApoioLiderInputEdit != null && pessoasApoioLiderInputEdit.Any())
                                            {
                                                foreach (var p in pessoasApoioLiderInputEdit
                                                    .Where(p => p.Cargo == "Pesquisador" || p.Cargo == "Coordenador")
                                                    .OrderBy(p => p.Nome))
                                                {
                                                    var value = (p.Nome ?? "")
                                                        .Split(new char[] { ',', ';' })[0]
                                                        .Trim();

                                                    <option value="@value">
                                                        @p.Nome (@p.Cargo) - @p.Casa [@p.Situacao]
                                                    </option>
                                                }
                                            }
                                        }
                                    </datalist>
                                    <select class="form-select d-none" id="UsuarioId-@Model.Id" disabled>
                                        <option value="">Selecione</option>
                                        @{
                                            var pessoasApoioLiderEdit = ViewData["PessoasApoio"] as List<PessoaModel>;
                                            var usuariosFunilLiderEdit = ViewData["Usuarios"] as List<UsuariosFunilDTO>;
                                            var lideresAdicionadosEdit = new HashSet<string>();

                                            if (pessoasApoioLiderEdit != null && usuariosFunilLiderEdit != null)
                                            {
                                                foreach (var p in pessoasApoioLiderEdit
                                                    .Where(p => p.Cargo == "Pesquisador" || p.Cargo == "Coordenador")
                                                    .OrderBy(p => p.Nome))
                                                {
                                                    var nomeLider = (p.Nome ?? "")
                                                        .Split(new char[] { ',', ';' })[0]
                                                        .Trim();

                                                    var usuarioLider = usuariosFunilLiderEdit.FirstOrDefault(u =>
                                                        string.Equals((u.UserName ?? "").Trim(), nomeLider, StringComparison.OrdinalIgnoreCase) ||
                                                        string.Equals((u.Email ?? "").Trim(), nomeLider, StringComparison.OrdinalIgnoreCase));

                                                    if (usuarioLider != null && lideresAdicionadosEdit.Add(usuarioLider.Id))
                                                    {
                                                        <option value="@usuarioLider.Id" selected="@(Model.Usuario?.Id == usuarioLider.Id)">
                                                            @p.Nome (@p.Cargo) - @p.Casa [@p.Situacao]
                                                        </option>
                                                    }
                                                }
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="mb-6">
                                    <label class="col-form-label" style="font-weight: 600" for="inputTextPessoas-@Model.Id">Membros</label>
                                    <div style="margin-left:3%;display:none" class="spinner-border" role="status" id="loadingOpcoesSelectPessoas-@Model.Id">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                    <input asp-for="MembrosEquipe" class="form-control d-none" id="inputTextPessoas-@Model.Id" type="text" />
                                    <button class="btn app-btn-primary" type="button" style="width: 100%;" id="botaoToggleCaixaRequestPessoas-@Model.Id"
                                            onclick="gerarOpcoesSelect('Pessoas', 'editarProspModal', '-@Model.Id', true)">Buscar</button>
                                    <div class="input-group flex-nowrap" id="caixaPesquisaPessoas-@Model.Id" style="display:block;">
                                        <select id="campoSelectPessoas-@Model.Id" class="form-select" multiple="true">
                                            @{
                                                var pessoas = ViewData["PessoasApoio"] as List<PessoaModel>;
                                                if (pessoas != null && pessoas.Any())
                                                {
                                                    foreach (var p in pessoas
                                                    .Where(p => p.Cargo == "Pesquisador" || p.Cargo == "Coordenador"))
                                                    {
                                                        var value = (p.Nome ?? "")
                                                        .Split(new char[] { ',', ';' })[0]
                                                        .Trim();

                                                        <option value="@value"
                                                                data-cargo="@p.Cargo"
                                                                data-casa="@p.Casa"
                                                                data-situacao="@p.Situacao">
                                                            @p.Nome (@p.Cargo) - @p.Casa [@p.Situacao]
                                                        </option>
                                                    }
                                                }
                                                else
                                                {
                                                    <option disabled>Arquivo apoio.csv não encontrado ou vazio</option>
                                                }

                                            }
                                        </select>
                                    </div>
                                </div>


                                <div class="col-md-8">
                                    <label asp-for="PotenciaisParceiros" class="form-label fw-semibold"></label>
                                    <input asp-for="PotenciaisParceiros" class="form-control" />
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="ParceiroInterno" class="form-label fw-semibold">
                                        @Html.DisplayNameFor(m => m.ParceiroInterno) <span class="text-danger">*</span>
                                    </label>

                                    <select asp-for="ParceiroInterno"
                                            class="form-select"
                                            asp-items="Html.GetEnumSelectList<ParceiroInterno>()" required>
                                        <option value="">Selecione</option>
                                    </select>
                                </div>


                            </div>
                        </div>
                        <!-- VALORES -->
                        <div class="tab-pane fade" id="tab-valores-@Model.Id">
                            @{
                                var composicaoValores = Model.ComposicaoValores?.OrderBy(valor => valor.Id).ToList()
                                    ?? new List<BaseDeProjetos.Models.ProspeccaoValorComposicao>();

                                if (!composicaoValores.Any())
                                {
                                    composicaoValores.Add(new BaseDeProjetos.Models.ProspeccaoValorComposicao());
                                }

                                var valorFinalTexto = Model.ValorFinal.HasValue ? Model.ValorFinal.Value.ToString("0.00") : string.Empty;
                            }

                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label asp-for="ValorEstimado" class="col-form-label" style="font-weight: 600"></label>
                                    <input name="ValorEstimado"
                                           id="ValorEstimado-@Model.Id"
                                           step="0.01"
                                           class="form-control"
                                           data-moeda="true"
                                           lang="pt-BR"
                                           value="@Model.ValorEstimado.ToString("0.00")" />
                                    <span asp-validation-for="ValorEstimado" class="text-danger"></span>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="ValorProposta" class="col-form-label" style="font-weight: 600"></label>
                                    <input name="ValorProposta"
                                           id="ValorProposta-@Model.Id"
                                           step="0.01"
                                           class="form-control"
                                           data-moeda="true"
                                           lang="pt-BR"
                                           value="@Model.ValorProposta.ToString("0.00")" />
                                    <span asp-validation-for="ValorProposta" class="text-danger"></span>
                                </div>

                                <div class="col-md-4">
                                    <label asp-for="ValorFinal" class="col-form-label" style="font-weight: 600"></label>
                                    <input name="ValorFinal"
                                           id="ValorFinal-@Model.Id"
                                           step="0.01"
                                           class="form-control"
                                           data-moeda="true"
                                           lang="pt-BR"
                                           value="@valorFinalTexto" />
                                    <span asp-validation-for="ValorFinal" class="text-danger"></span>
                                </div>

                                <div class="col-12">
                                    <div class="valores-composicao-header">
                                        <strong>Composi&ccedil;&atilde;o de valores</strong>
                                        <button type="button"
                                                class="btn btn-outline-primary btn-sm"
                                                data-add-composicao
                                                data-list="#composicao-valores-list-@Model.Id"
                                                data-template="#composicao-valores-template-@Model.Id">
                                            Adicionar linha
                                        </button>
                                    </div>

                                    <div id="composicao-valores-list-@Model.Id"
                                         class="valores-composicao-list"
                                         data-next-index="@composicaoValores.Count">
                                        @for (int i = 0; i < composicaoValores.Count; i++)
                                        {
                                            <div class="valores-composicao-row">
                                                <input name="ComposicaoValores[@i].Origem"
                                                       class="form-control"
                                                       placeholder="Origem. Ex.: LS, parceiro, empresa"
                                                       value="@composicaoValores[i].Origem" />
                                                <select name="ComposicaoValores[@i].Tipo" class="form-select">
                                                    <option value="">Tipo</option>
                                                    <option value="Coordenacao" selected="@(composicaoValores[i].Tipo == "Coordenacao")">Coordena&ccedil;&atilde;o</option>
                                                    <option value="Parceiro" selected="@(composicaoValores[i].Tipo == "Parceiro")">Parceiro</option>
                                                    <option value="Empresa" selected="@(composicaoValores[i].Tipo == "Empresa")">Empresa</option>
                                                    <option value="Outro" selected="@(composicaoValores[i].Tipo == "Outro")">Outro</option>
                                                </select>
                                                <select name="ComposicaoValores[@i].Natureza" class="form-select">
                                                    <option value="">Natureza</option>
                                                    <option value="Financeiro" selected="@(composicaoValores[i].Natureza == "Financeiro")">Financeiro</option>
                                                    <option value="Economico" selected="@(composicaoValores[i].Natureza == "Economico")">Econ&ocirc;mico</option>
                                                </select>
                                                <input name="ComposicaoValores[@i].Valor"
                                                       step="0.01"
                                                       class="form-control"
                                                       data-moeda="true"
                                                       lang="pt-BR"
                                                       placeholder="Valor"
                                                       value="@(composicaoValores[i].Valor.HasValue ? composicaoValores[i].Valor.Value.ToString("0.00") : string.Empty)" />
                                                <input name="ComposicaoValores[@i].Observacao"
                                                       class="form-control"
                                                       placeholder="Observa&ccedil;&atilde;o"
                                                       value="@composicaoValores[i].Observacao" />
                                            </div>
                                        }
                                    </div>

                                    <template id="composicao-valores-template-@Model.Id">
                                        <div class="valores-composicao-row">
                                            <input name="ComposicaoValores[__index__].Origem" class="form-control" placeholder="Origem. Ex.: LS, parceiro, empresa" />
                                            <select name="ComposicaoValores[__index__].Tipo" class="form-select">
                                                <option value="">Tipo</option>
                                                <option value="Coordenacao">Coordena&ccedil;&atilde;o</option>
                                                <option value="Parceiro">Parceiro</option>
                                                <option value="Empresa">Empresa</option>
                                                <option value="Outro">Outro</option>
                                            </select>
                                            <select name="ComposicaoValores[__index__].Natureza" class="form-select">
                                                <option value="">Natureza</option>
                                                <option value="Financeiro">Financeiro</option>
                                                <option value="Economico">Econ&ocirc;mico</option>
                                            </select>
                                            <input name="ComposicaoValores[__index__].Valor" step="0.01" class="form-control" data-moeda="true" lang="pt-BR" placeholder="Valor" />
                                            <input name="ComposicaoValores[__index__].Observacao" class="form-control" placeholder="Observa&ccedil;&atilde;o" />
                                        </div>
                                    </template>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- FOOTER -->
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        Cancelar
                    </button>
                    <button type="submit" class="btn app-btn-primary">
                        Salvar
                    </button>
                </div>

            </form>

        </div>
    </div>
</div>

<script>
    (function () {
        if (window.__composicaoValoresInit) {
            return;
        }

        window.__composicaoValoresInit = true;

        document.addEventListener('click', function (event) {
            var button = event.target.closest('[data-add-composicao]');
            if (!button) {
                return;
            }

            var list = document.querySelector(button.getAttribute('data-list'));
            var template = document.querySelector(button.getAttribute('data-template'));

            if (!list || !template) {
                return;
            }

            var index = parseInt(list.getAttribute('data-next-index') || '0', 10);
            var wrapper = document.createElement('div');
            wrapper.innerHTML = template.innerHTML.replace(/__index__/g, index);
            list.appendChild(wrapper.firstElementChild);
            list.setAttribute('data-next-index', index + 1);
        });
    })();
</script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
