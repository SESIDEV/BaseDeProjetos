@model BaseDeProjetos.Models.FollowUp
@using BaseDeProjetos.Models.Enums
@using Microsoft.AspNetCore.Http
@using System
@using System.Globalization
@{
    if (!(Context.Session.GetString("_Casa") is null))
    {
        ViewData["Area"] = Context.Session.GetString("_Casa");
    }
    IEnumerable<SelectListItem> FiltrarExcecao(IEnumerable<SelectListItem> selectList, Prospeccao prospeccao)
    {
        /* 
         * Ordenamos primeiro por data, depois ordenamos pelo valor do enum.
         * Motivo: Se tivermos 2 status, digamos: "Contato Inicial" e "Com Proposta" na mesma data,
         * o código irá escolher "at random" e permitirá com que a pessoa adicione um status não válido.
         * Em outras palavras, mesmo que o "último" status seja "Com Proposta", 
         * caso eles estejam na mesma data o usuário ainda sim poderia adicionar "Contato Inicial".
        */

        // Determinar status atual desempantando por Data e Id para casos de datas iguais
        StatusProspeccao statusAtual = prospeccao.Status.OrderByDescending(s => s.Data).ThenByDescending(s => s.Id).ThenByDescending(s => s.Status).First().Status;

        if (statusAtual == StatusProspeccao.Planejada)
        {
            return selectList.Where(status => int.Parse(status.Value) == (int)StatusProspeccao.ContatoInicial);
        }
        else
        {
            int statusAtualValue = (int)statusAtual;

            return selectList.Where(status =>
            {
                int valorStatus = int.Parse(status.Value);
                return valorStatus >= statusAtualValue
                    && valorStatus != (int)StatusProspeccao.Planejada
                    && valorStatus != (int)StatusProspeccao.Agregada;
            });
        }
    }


    string LimitarData(Prospeccao prosp)
    {
        return prosp.Status.OrderBy(s => s.Data).ThenBy(s => s.Id).Last().Data.ToString("yyyy-MM-dd");
    }

    string LimitarDataFormat(Prospeccao prosp)
    {
        return prosp.Status.OrderBy(s => s.Data).ThenBy(s => s.Id).Last().Data.ToString("dd/MM/yyyy", CultureInfo.CreateSpecificCulture("pt-BR"));
    }
}

@{
    var prosp = ViewData["prospeccao"] as Prospeccao;
}


<div class="modal fade" id="CreateFollowupProspModal-@prosp.Id" aria-hidden="true"
     aria-labelledby="#CreateFollowupProspModal-@prosp.Id-Label" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered funil-status-modal-dialog">
        <div class="modal-content funil-status-modal">
            <form class="form-submit" asp-controller="FunilDeVendas" asp-action="Atualizar" method="POST">
                <div class="funil-status-modal-header">
                    <div>
                        <h1 class="funil-status-modal-title" id="CreateFollowupProspModal-@prosp.Id-Label2">
                            Adicionar novo status
                        </h1>
                        <p>Atualize o est&aacute;gio da prospec&ccedil;&atilde;o para acompanhar a evolu&ccedil;&atilde;o.</p>
                    </div>
                    <button type="button" class="btn-close funil-status-modal-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="funil-status-modal-body">
                    <input asp-for="OrigemID" type="hidden" value="@prosp.Id" />

                    <div class="funil-status-field">
                        <label asp-for="Data" class="form-label">Data da atualiza&ccedil;&atilde;o</label>
                        <div class="funil-status-input-icon">
                            <i class="bi bi-calendar3" aria-hidden="true"></i>
                            <input asp-for="Data" type="date" class="form-control" min="@LimitarData(@prosp)" required />
                        </div>
                        <small class="form-text text-muted">Data m&iacute;nima: @LimitarDataFormat(@prosp)</small>
                        <span asp-validation-for="Data" class="text-danger"></span>
                    </div>

                    <div class="funil-status-field">
                        <label asp-for="Status" class="form-label">Novo status</label>
                        <select asp-for="Status"
                                class="form-select"
                                asp-items="FiltrarExcecao(Html.GetEnumSelectList<StatusProspeccao>(), @prosp)"
                                required>
                            <option value="">Escolha um est&aacute;gio</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>

                    <div class="funil-status-field">
                        <label asp-for="Anotacoes" class="form-label">Observa&ccedil;&otilde;es</label>
                        <textarea class="form-control" asp-for="Anotacoes" rows="4" placeholder="Adicione detalhes sobre a mudan&ccedil;a de status..."></textarea>
                        <span asp-validation-for="Anotacoes" class="text-danger"></span>
                    </div>
                </div>

                <div class="funil-status-modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary">Salvar status</button>
                </div>
            </form>
        </div>
    </div>
</div>
<script>
    (function () {
        var modal = document.getElementById('CreateFollowupProspModal-@prosp.Id');
        var dateControl = modal ? modal.querySelector('input[type="date"]') : null;
        if (dateControl) {
            dateControl.max = new Date(new Date().getTime() - new Date().getTimezoneOffset() * 60000).toISOString().split("T")[0];
        }
    })();
</script>
