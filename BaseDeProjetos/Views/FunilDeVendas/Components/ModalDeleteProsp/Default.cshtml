@using BaseDeProjetos.Models.Enums;
@model BaseDeProjetos.Models.Prospeccao

@{
    ViewData["Title"] = "deletar";
    var ultimoStatus = Model?.Status?
        .OrderBy(p => p.Data)
        .ThenBy(p => p.Id)
        .LastOrDefault();
}

<div class="modal fade" id="deletarProspModal-@Model.Id" aria-hidden="true"
    aria-labelledby="deletarProspModal-@Model.Id-Label" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="deletarProspModal-@Model.Id-Label">Deletar Prospecção</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2">
                    <label asp-for="Id" class="col-form-label" style="font-weight: 600"></label>
                    <div class="form-control" readonly>@Model.Id</div>
                </div>
                <div class="mb-2">
                    <label asp-for="Casa" class="col-form-label" style="font-weight: 600"></label>
                    <div class="form-control" readonly>@Model.Casa</div>
                </div>
                <div class="mb-2">
                    <label asp-for="NomeProspeccao" class="col-form-label" style="font-weight: 600"></label>
                    <div class="form-control" readonly>@Model.NomeProspeccao</div>
                </div>
                <div class="mb-2">
                    <label class="col-form-label" style="font-weight: 600">Líder da Prospecção</label>
                    <div class="form-control" readonly>@(!string.IsNullOrWhiteSpace(Model.LiderNome) ? Model.LiderNome : Model.Usuario?.UserName ?? "Líder não informado")</div>
                </div>
                <div class="mb-2">
                    <label class="col-form-label" style="font-weight: 600">Último Status:</label>
                    <div style="font-size: inherit" readonly>
                        @(ultimoStatus != null ? ultimoStatus.Status.GetDisplayName() : "Sem status")
                    </div>
                    <div class="form-control" readonly>@(ultimoStatus?.Anotacoes ?? "")</div>
                </div>
            </div>
            <div class="modal-footer">
                <form asp-action="Delete" asp-route-id="Id" method="post">
                    <button type="button" class="btn app-btn-primary"
                        data-bs-target="#deletarProspModal-@Model.Id" data-bs-toggle="modal">
                        Voltar
                    </button>
                    <input type="hidden" asp-for="Id" />
                    <input type="submit" value="Deletar" class="btn btn-submit text-white btn-danger" />
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
@{
await Html.RenderPartialAsync("_ValidationScriptsPartial");
}
}


